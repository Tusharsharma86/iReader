{
  "expo": {
    "name": "iReader",
    "slug": "ireader",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ireader",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ireader.app"
    },
    "android": {
      "package": "com.ireader.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0A0A0A"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "de16b6bf-2020-41c9-9b65-96af3a45d928"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/de16b6bf-2020-41c9-9b65-96af3a45d928"
    }
  }
}
