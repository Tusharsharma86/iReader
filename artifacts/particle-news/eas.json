{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
  "distribution": "internal",
  "channel": "preview",
  "android": {
    "buildType": "apk"
  },
  "env": {
    "EXPO_PUBLIC_API_URL": "https://ireader.onrender.com"
  },
  "buildArtifactPaths": ["android/app/build/outputs/**/*.apk"],
  "prebuildCommand": "pnpm install --no-frozen-lockfile"
}
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ireader.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
